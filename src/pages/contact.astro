---
const { pathname } = Astro.url;
const base = import.meta.env.BASE_URL;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>Contact — Ollie Garden</title>
    <meta name="description" content="Get in touch with Ollie Garden for yard work in Sooke, Shirley, and Metchosin." />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --green-dark:  #2d6a2d;
        --green-mid:   #4a9e4a;
        --green-light: #e8f5e9;
        --tan:         #f5f0e8;
        --white:       #ffffff;
        --text:        #2c2c2c;
        --radius:      12px;
        --max-w:       860px;
      }

      body {
        font-family: "Segoe UI", system-ui, sans-serif;
        background: var(--tan);
        color: var(--text);
        line-height: 1.6;
      }

      a { color: var(--green-dark); }

      .hero {
        background: linear-gradient(160deg, #2d5a2d 0%, #3d7a3d 100%);
        color: var(--white);
        text-align: center;
        padding: 1.75rem 1.5rem 1.5rem;
      }

      .hero-badge {
        display: inline-block;
        background: rgba(255,255,255,0.15);
        border-radius: 999px;
        padding: 0.2rem 0.9rem;
        font-size: 0.75rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 0.5rem;
      }

      .hero h1 {
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 700;
        line-height: 1.1;
      }

      .hero h1 span { color: #a8dba8; }

      .site-nav {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        padding: 0.75rem 1rem;
        background: var(--white);
        border-bottom: 1px solid #dceadc;
      }

      .site-nav a {
        font-size: 0.875rem;
        font-weight: 600;
        text-decoration: none;
        color: var(--green-dark);
      }

      .site-nav a:hover { text-decoration: underline; }
      .site-nav a.active { color: var(--white); background: var(--green-dark); border-radius: 6px; padding: 0.2rem 0.7rem; text-decoration: none; }

      .section {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }

      .section-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--green-dark);
        margin-bottom: 1.25rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid var(--green-light);
      }

      .form-card {
        max-width: 560px;
        margin: 0 auto;
        background: var(--white);
        border: 1px solid #d0dfd0;
        border-radius: var(--radius);
        padding: 2rem;
      }

      .form-group { margin-bottom: 1.1rem; }

      label {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--green-dark);
        margin-bottom: 0.35rem;
      }

      input, textarea, select {
        width: 100%;
        padding: 0.6rem 0.85rem;
        border: 1.5px solid #ccc;
        border-radius: 8px;
        font-size: 0.95rem;
        font-family: inherit;
        background: var(--tan);
        transition: border-color 0.15s;
      }

      input:focus, textarea:focus, select:focus {
        outline: none;
        border-color: var(--green-mid);
        background: var(--white);
      }

      textarea { min-height: 110px; resize: vertical; }

      .btn-submit {
        display: block;
        width: 100%;
        padding: 0.8rem 1rem;
        background: var(--green-dark);
        color: var(--white);
        font-size: 1rem;
        font-weight: 700;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        letter-spacing: 0.03em;
        margin-top: 0.5rem;
        transition: background 0.15s;
      }

      .btn-submit:hover { background: var(--green-mid); }

      .form-note {
        text-align: center;
        font-size: 0.8rem;
        color: #888;
        margin-top: 0.75rem;
      }

      footer {
        text-align: center;
        padding: 1.5rem 1rem;
        font-size: 0.82rem;
        color: #888;
        border-top: 1px solid #ddd;
      }
    </style>
  </head>
  <body>

    <header class="hero">
      <div class="hero-badge">Youth Gardening Services</div>
      <h1>Ollie <span>Garden</span></h1>
    </header>

    <nav class="site-nav">
      <a href={base} class={!pathname.includes('testimonials') && !pathname.includes('contact') ? 'active' : ''}>Services</a>
      <a href={`${base}testimonials`} class={pathname.includes('testimonials') ? 'active' : ''}>Testimonials</a>
      <a href={`${base}contact`} class={pathname.includes('contact') ? 'active' : ''}>Contact</a>
    </nav>

    <section class="section">
      <h2 class="section-title">Get in Touch</h2>
      <div class="form-card">
        <form
          action="https://formspree.io/f/xgorzvbk"
          method="POST"
        >
          <div class="form-group">
            <label for="name">Your Name</label>
            <input type="text" id="name" name="name" placeholder="Jane Smith" required />
          </div>
          <div class="form-group">
            <label for="email">Your Email</label>
            <input type="email" id="email" name="email" placeholder="jane@example.com" required />
          </div>
          <div class="form-group">
            <label for="service">Service Needed</label>
            <select id="service" name="service">
              <option value="">— Choose a service —</option>
              <option>Whipper Snipping</option>
              <option>Weeding (gardens, flower beds, etc.)</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">Tell me about the job</label>
            <textarea id="message" name="message" placeholder="A quick description of what you need done and when…"></textarea>
          </div>
          <button type="submit" class="btn-submit">Send Message</button>
          <p class="form-note">You'll receive a reply by email. Rate is $20/hr.</p>
        </form>
      </div>
    </section>

    <footer>
      &copy; {new Date().getFullYear()} Ollie Garden &mdash; Youth Gardening Services
    </footer>

  </body>
</html>
