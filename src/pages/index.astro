---
const { pathname } = Astro.url;
const base = import.meta.env.BASE_URL;
const services = [
  {
    title: "Whipper snipping",
    rate: "Hourly rate",
    desc: "Edge trimming and other tidying",
  },
  {
    title: "Weeding",
    rate: "Hourly rate",
    desc: "Hand-pulling weeds.",
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>Ollie Garden — Youth Gardening Services</title>
    <meta
      name="description"
      content="Ollie Garden — Sooke, Shirley &amp; Metchosin. $20/hr."
    />
    <style>
      /* ---------- reset & base ---------- */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --green-dark:  #2d6a2d;
        --green-mid:   #4a9e4a;
        --green-light: #e8f5e9;
        --tan:         #f5f0e8;
        --white:       #ffffff;
        --text:        #2c2c2c;
        --radius:      12px;
        --max-w:       860px;
      }

      body {
        font-family: "Segoe UI", system-ui, sans-serif;
        background: var(--tan);
        color: var(--text);
        line-height: 1.6;
      }

      a { color: var(--green-dark); }

      .hero {
        background: linear-gradient(160deg, #2d5a2d 0%, #3d7a3d 100%);
        color: var(--white);
        text-align: center;
        padding: 1.75rem 1.5rem 1.5rem;
      }

      .hero-badge {
        display: inline-block;
        background: rgba(255,255,255,0.15);
        border-radius: 999px;
        padding: 0.2rem 0.9rem;
        font-size: 0.75rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 0.5rem;
      }

      .hero h1 {
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 700;
        line-height: 1.1;
        margin-bottom: 0.4rem;
      }

      .hero h1 span { color: #a8dba8; }

      .hero-tagline {
        font-size: 0.95rem;
        opacity: 0.85;
        max-width: 480px;
        margin: 0.4rem auto 0;
      }

      /* ---------- nav ---------- */
      .site-nav {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        padding: 0.75rem 1rem;
        background: var(--white);
        border-bottom: 1px solid #dceadc;
      }

      .site-nav a {
        font-size: 0.875rem;
        font-weight: 600;
        text-decoration: none;
        color: var(--green-dark);
      }

      .site-nav a:hover { text-decoration: underline; }
      .site-nav a.active { color: var(--white); background: var(--green-dark); border-radius: 6px; padding: 0.2rem 0.7rem; text-decoration: none; }

      /* ---------- sections ---------- */
      .section {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }

      .section-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--green-dark);
        margin-bottom: 1.25rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid var(--green-light);
      }

      /* ---------- services grid ---------- */
      .services-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        gap: 1rem;
      }

      .service-card {
        background: var(--white);
        border: 1px solid #dceadc;
        border-radius: var(--radius);
        padding: 1.4rem;
        transition: box-shadow 0.15s;
      }

      .service-card:hover { box-shadow: 0 4px 14px rgba(0,0,0,0.07); }

      .service-card h3 {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .svc-rate {
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--green-dark);
        background: var(--green-light);
        border-radius: 999px;
        padding: 0.1rem 0.55rem;
      }

      .service-card p {
        font-size: 0.875rem;
        color: #555;
        line-height: 1.55;
      }

      /* ---------- cta links ---------- */
      .cta-row {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 2rem;
      }

      .cta-link {
        display: inline-block;
        padding: 0.7rem 1.4rem;
        border-radius: 8px;
        font-size: 0.95rem;
        font-weight: 700;
        text-decoration: none;
        transition: background 0.15s;
      }

      .cta-link.primary {
        background: var(--green-dark);
        color: var(--white);
      }

      .cta-link.primary:hover { background: var(--green-mid); }

      .cta-link.secondary {
        background: var(--green-light);
        color: var(--green-dark);
        border: 1.5px solid #b2d8b2;
      }

      .cta-link.secondary:hover { background: #d0ecd0; }

      /* ---------- footer ---------- */
      footer {
        text-align: center;
        padding: 1.5rem 1rem;
        font-size: 0.82rem;
        color: #888;
        border-top: 1px solid #ddd;
      }
    </style>
  </head>
  <body>

    <!-- HERO -->
    <header class="hero">
      <div class="hero-badge">Youth Gardening Services</div>
      <h1>Ollie <span>Garden</span></h1>
      <p class="hero-tagline">
        Reliable, hardworking yardwork, serving Sooke, Shirley, and Metchosin.
      </p>
    </header>

    <!-- NAV -->
    <nav class="site-nav">
      <a href={base} class={!pathname.includes('testimonials') && !pathname.includes('contact') ? 'active' : ''}>Services</a>
      <a href={`${base}testimonials`} class={pathname.includes('testimonials') ? 'active' : ''}>Testimonials</a>
      <a href={`${base}contact`} class={pathname.includes('contact') ? 'active' : ''}>Contact</a>
    </nav>

    <!-- SERVICES -->
    <section class="section">
      <h2 class="section-title">Services</h2>
      <div class="services-grid">
        {services.map((s) => (
          <div class="service-card">
            <h3>{s.title} <span class="svc-rate">{s.rate}</span></h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>

      <div class="cta-row">
        <a class="cta-link primary" href={`${import.meta.env.BASE_URL}contact`}>Get in Touch</a>
      </div>
    </section>

    <footer>
      &copy; {new Date().getFullYear()} Ollie Garden &mdash; Youth Gardening Services
    </footer>

  </body>
</html>
