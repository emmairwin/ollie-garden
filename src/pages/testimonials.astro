---
const { pathname } = Astro.url;
const base = import.meta.env.BASE_URL;
const testimonials: { name: string; quote: string }[] = [
  // Add testimonials here, e.g.:
  // { name: "Jane S.", quote: "Ollie did a fantastic job on our garden!" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>Testimonials — Ollie Garden</title>
    <meta name="description" content="See what customers say about Ollie Garden's yard work in Sooke, Shirley, and Metchosin." />
    <link rel="canonical" href="https://ollie-garden.com/testimonials" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Testimonials — Ollie Garden" />
    <meta property="og:description" content="See what customers say about Ollie Garden's yard work in Sooke, Shirley, and Metchosin." />
    <meta property="og:url" content="https://ollie-garden.com/testimonials" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --green-dark:  #2d6a2d;
        --green-mid:   #4a9e4a;
        --green-light: #e8f5e9;
        --brown:       #795548;
        --tan:         #f5f0e8;
        --white:       #ffffff;
        --text:        #2c2c2c;
        --radius:      12px;
        --max-w:       860px;
      }

      body {
        font-family: "Segoe UI", system-ui, sans-serif;
        background: var(--tan);
        color: var(--text);
        line-height: 1.6;
      }

      a { color: var(--green-dark); }

      .hero {
        background: linear-gradient(160deg, #2d5a2d 0%, #3d7a3d 100%);
        color: var(--white);
        text-align: center;
        padding: 1.75rem 1.5rem 1.5rem;
      }

      .hero-badge {
        display: inline-block;
        background: rgba(255,255,255,0.15);
        border-radius: 999px;
        padding: 0.2rem 0.9rem;
        font-size: 0.75rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 0.5rem;
      }

      .hero h1 {
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 700;
        line-height: 1.1;
      }

      .hero h1 span { color: #a8dba8; }

      .section {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }

      .section-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--green-dark);
        margin-bottom: 1.25rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid var(--green-light);
      }

      .testimonials-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1rem;
      }

      .testimonial-card {
        background: var(--white);
        border: 1px solid #dceadc;
        border-radius: var(--radius);
        padding: 1.4rem;
      }

      .testimonial-card blockquote {
        font-size: 0.925rem;
        color: #444;
        line-height: 1.65;
        margin-bottom: 0.75rem;
      }

      .testimonial-card cite {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--green-dark);
        font-style: normal;
      }

      .empty-state {
        text-align: center;
        color: #888;
        font-size: 0.9rem;
        padding: 3rem 0;
      }

      .back-link {
        display: inline-block;
        margin-bottom: 1.5rem;
        font-size: 0.875rem;
        font-weight: 600;
        text-decoration: none;
      }

      .back-link:hover { text-decoration: underline; }

      .site-nav {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        padding: 0.75rem 1rem;
        background: var(--white);
        border-bottom: 1px solid #dceadc;
      }

      .site-nav a {
        font-size: 0.875rem;
        font-weight: 600;
        text-decoration: none;
        color: var(--green-dark);
      }

      .site-nav a:hover { text-decoration: underline; }
      .site-nav a.active { color: var(--white); background: var(--green-dark); border-radius: 6px; padding: 0.2rem 0.7rem; text-decoration: none; }

      footer {
        text-align: center;
        padding: 1.5rem 1rem;
        font-size: 0.82rem;
        color: #888;
        border-top: 1px solid #ddd;
      }
    </style>
  </head>
  <body>

    <header class="hero">
      <div class="hero-badge">Youth Gardening Services</div>
      <h1>Ollie <span>Garden</span></h1>
    </header>

    <nav class="site-nav">
      <a href={base} class={!pathname.includes('testimonials') && !pathname.includes('contact') ? 'active' : ''}>Services</a>
      <a href={`${base}testimonials`} class={pathname.includes('testimonials') ? 'active' : ''}>Testimonials</a>
      <a href={`${base}contact`} class={pathname.includes('contact') ? 'active' : ''}>Contact</a>
    </nav>

    <section class="section">
      <h2 class="section-title">Testimonials</h2>

      {testimonials.length > 0 ? (
        <div class="testimonials-grid">
          {testimonials.map((t) => (
            <div class="testimonial-card">
              <blockquote>"{t.quote}"</blockquote>
              <cite>— {t.name}</cite>
            </div>
          ))}
        </div>
      ) : (
        <p class="empty-state">Testimonials coming soon!</p>
      )}
    </section>

    <footer>
      &copy; {new Date().getFullYear()} Ollie Garden &mdash; Youth Gardening Services
    </footer>

  </body>
</html>
